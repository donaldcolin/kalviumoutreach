{
  "expo": {
    "name": "Kalvium Outreach",
    "slug": "kalvium-outreach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LOGOsmall.png",
    "splash": {
      "image": "./assets/LOGO.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF8F5",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "package": "com.kalvium.outreach",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "FOREGROUND_SERVICE_MICROPHONE",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Kalvium Outreach needs camera access for check-in photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Kalvium Outreach needs location access to track your route during field visits.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Kalvium Outreach needs microphone access to record meetings.",
          "backgroundRecording": true
        }
      ],
      "@react-native-community/datetimepicker",
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "7c3b7db9-8bd9-4b90-985b-44ec35ff2b84"
      }
    },
    "ios": {
      "bundleIdentifier": "com.kalvium.outreach",
      "googleServicesFile": "./GoogleService-Info.plist"
    }
  }
}
