rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read their own profile, admins can read all
    match /users/{userId} {
      allow read: if request.auth != null;
      // Only allow users to update their own lastKnownLocation (prevent role escalation)
      // We include the nested paths because the deployed APK uses {merge: true} which generates deep field updates
      allow update: if request.auth != null 
                    && request.auth.uid == userId 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'lastKnownLocation',
                      'lastKnownLocation.lat',
                      'lastKnownLocation.lng',
                      'lastKnownLocation.ts',
                      'lastKnownLocation.updatedAt'
                    ]);
      allow create: if request.auth != null 
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teamLead', 'regionalManager'];
      allow delete: if false; // Only manageable from server/admin SDK
    }

    // Daily tracks, visits, stops, and pings are scoped to the executive
    match /dailyTracks/{trackId} {
      allow read: if request.auth != null;
      // An associate can only write to a track document if its ID starts with their own user ID. Admins/TLs can manage any track.
      allow write: if request.auth != null && (trackId.matches(request.auth.uid + '_.*') || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'executive');
      
      match /locations/{locationId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && trackId.matches(request.auth.uid + '_.*');
      }
      match /visits/{visitId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && trackId.matches(request.auth.uid + '_.*');
      }
    }

    // Visits collection (top level)
    match /visits/{visitId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && resource.data.executiveId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.executiveId == request.auth.uid;
    }

    // Meetings
    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && resource.data.executiveId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.executiveId == request.auth.uid;
    }

    // Appointments
    match /appointments/{appId} {
      allow read: if request.auth != null;
      // Associate can update their own tasks (e.g. mark complete)
      allow update: if request.auth != null && resource.data.executiveId == request.auth.uid;
      // TLs/Admins can manage tasks (create, update, delete)
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'executive';
    }

    // Schools are readable by any authenticated user
    match /schools/{schoolId} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin can edit schools
    }

    // Location Requests
    match /locationRequests/{reqId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // CRM Activities synced from LeadSquared — readable by any authenticated user
    match /crmActivities/{activityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (resource == null || resource.data.executiveId == request.auth.uid) && (request.resource == null || request.resource.data.executiveId == request.auth.uid);
    }

    // Push queue for syncing to LeadSquared
    match /pushQueue/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (resource == null || resource.data.executiveId == request.auth.uid) && (request.resource == null || request.resource.data.executiveId == request.auth.uid);
    }

    // Discreet meeting recordings
    match /meetingRecordings/{recordingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && resource.data.executiveId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.executiveId == request.auth.uid;
    }

    // Ongoing walk-in sessions (one per user, keyed by userId)
    match /ongoingWalkIns/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // System logs — write-only from the mobile app (so users can't read others' logs)
    // Only TLs/Admins can read logs via the website
    match /system_logs/{logId} {
      // Allow read if user is not an executive
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'executive';
      // Allow create only if the log's associateId matches the caller's auth UID
      allow create: if request.auth != null && request.resource.data.associateId == request.auth.uid;
      allow update, delete: if false; // Logs are immutable
    }

    // Lead Access Requests — associates request access, managers approve
    match /leadAccessRequests/{reqId} {
      // Anyone authenticated can read (to check their own requests)
      allow read: if request.auth != null;
      // Any authenticated user can create a request (requestedBy must be their own UID)
      allow create: if request.auth != null && request.resource.data.requestedBy == request.auth.uid;
      // Only TLs/Admins can approve (update status)
      allow update: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'executive';
      allow delete: if false;
    }
  }
}
