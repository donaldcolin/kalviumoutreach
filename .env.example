# Kalvium Outreach — Environment Variables
# Copy this file to .env and fill in the values.

# Google Places API key (for stop classification)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# LeadSquared CRM credentials
EXPO_PUBLIC_LEADSQUARED_HOST=
EXPO_PUBLIC_LEADSQUARED_ACCESS_KEY=
EXPO_PUBLIC_LEADSQUARED_SECRET_KEY=

# Transistorsoft Background Geolocation license key
# (trial mode works for development without a key)
BG_GEOLOCATION_LICENSE_KEY=
